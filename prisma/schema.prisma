generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── Core models (used via Prisma client) ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  passwordHash  String?
  image         String?
  role          String    @default("user")
  tier          String    @default("none")
  status        String    @default("lead")
  quizCategory  String?
  quizSituation String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  orders              Order[]
  journalEntries      JournalEntry[]
  taskCompletions     TaskCompletion[]
  PsychologistProfile PsychologistProfile?
  availableSlots      AvailableSlot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id          String   @id @default(cuid())
  userId      String?
  email       String
  name        String
  phone       String?
  product     String
  productName String
  amount      Int
  status      String   @default("pending")
  paymentId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  source    String?
  createdAt DateTime @default(now())
}

model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  date        String
  type        String   @default("daily")
  mood        Int      @default(5)
  anxiety     Int      @default(5)
  urgeToWrite Int      @default(1)
  energy      Int      @default(5)
  sleep       String   @default("ok")
  triggers    String?
  helpers     String?
  note        String?
  nextStep    String?
  situation   String?
  intensity   Int?
  wantToDo    String?
  saferAction String?
  weekSum1    String?
  weekSum2    String?
  weekSum3    String?
  weekSum4    String?
  weekSum5    String?
  sharedWithSpecialist Boolean @default(false)
  isDraft              Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}

model PsychologistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  speciality  String?
  approach    String?
  education   String?
  experience  String?
  bio         String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

// ── Scheduling (AvailableSlot used via Prisma client in slots route) ───────────

model AvailableSlot {
  id          String   @id @default(cuid())
  doctorId    String
  startAt     DateTime
  durationMin Int      @default(45)
  isBooked    Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

// ── Raw-SQL tables (tables exist in DB; code uses $queryRawUnsafe) ────────────
// These are defined in schema so `prisma db push` creates the tables.
// Prisma client is NOT used for CRUD — only raw SQL. No relations declared.

model Group {
  id             String   @id @default(cuid())
  title          String
  psychologistId String?
  curatorId      String?
  status         String   @default("recruiting")
  currentWeek    Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GroupParticipant {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  status   String   @default("active")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model GroupMeeting {
  id          String    @id @default(cuid())
  groupId     String
  week        Int       @default(1)
  title       String?
  scheduledAt DateTime?
  meetingLink String?
  notes       String?
  createdAt   DateTime  @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  slotId    String?
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  relatedId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model SpecialistNote {
  id           String   @id @default(cuid())
  userId       String
  specialistId String
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Recommendation {
  id           String   @id @default(cuid())
  userId       String
  specialistId String
  content      String
  createdAt    DateTime @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
}

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  version     String?
  ip          String?
  givenAt     DateTime @default(now())
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  goals     String?
  about     String?
  situation String?
  partner   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
