generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  passwordHash  String?
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  orders              Order[]
  journalEntries      JournalEntry[]
  taskCompletions     TaskCompletion[]
  PsychologistProfile PsychologistProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id          String   @id @default(cuid())
  userId      String?
  email       String
  name        String
  phone       String?
  product     String
  productName String
  amount      Int
  status      String   @default("pending")
  paymentId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  source    String?
  createdAt DateTime @default(now())
}

model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  date        String
  type        String   @default("daily")

  // Daily entry fields
  mood        Int      @default(5)
  anxiety     Int      @default(5)
  urgeToWrite Int      @default(1)
  energy      Int      @default(5)
  sleep       String   @default("ok")
  triggers    String?  // JSON array
  helpers     String?  // JSON array
  note        String?
  nextStep    String?

  // Quick crisis entry fields
  situation   String?
  intensity   Int?
  wantToDo    String?
  saferAction String?

  // Weekly summary fields
  weekSum1    String?
  weekSum2    String?
  weekSum3    String?
  weekSum4    String?
  weekSum5    String?

  sharedWithSpecialist Boolean @default(false)
  isDraft              Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}

model PsychologistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  speciality  String?
  approach    String?
  education   String?
  experience  String?
  bio         String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

