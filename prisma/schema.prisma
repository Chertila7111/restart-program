generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── Core models (used via Prisma client) ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  passwordHash  String?
  image         String?
  role          String    @default("user")
  tier          String    @default("none")
  status        String    @default("lead")
  quizCategory  String?
  quizSituation String?
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  orders              Order[]
  journalEntries      JournalEntry[]
  taskCompletions     TaskCompletion[]
  PsychologistProfile PsychologistProfile?
  availableSlots      AvailableSlot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id                  String    @id @default(cuid())
  userId              String?
  email               String
  name                String
  phone               String?
  product             String
  productName         String
  amount              Int
  status              String    @default("pending")
  paymentId           String?
  refundStatus        String?
  refundAmount        Int?
  refundReason        String?
  refundRequestedAt   DateTime?
  refundCompletedAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  source    String?
  createdAt DateTime @default(now())
}

model JournalEntry {
  id                   String   @id @default(cuid())
  userId               String
  date                 String
  type                 String   @default("daily")
  mood                 Int      @default(5)
  anxiety              Int      @default(5)
  urgeToWrite          Int      @default(1)
  energy               Int      @default(5)
  sleep                String   @default("ok")
  triggers             String?
  helpers              String?
  note                 String?
  nextStep             String?
  situation            String?
  intensity            Int?
  wantToDo             String?
  saferAction          String?
  weekSum1             String?
  weekSum2             String?
  weekSum3             String?
  weekSum4             String?
  weekSum5             String?
  sharedWithSpecialist Boolean  @default(false)
  isDraft              Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}

model PsychologistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  speciality  String?
  approach    String?
  education   String?
  experience  String?
  bio         String?
  workStyle   String?
  quote       String?
  photoUrl    String?
  meetingLink String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

// ── Scheduling ────────────────────────────────────────────────────────────────

model AvailableSlot {
  id          String   @id @default(cuid())
  doctorId    String
  startAt     DateTime
  durationMin Int      @default(45)
  isBooked    Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  slotId    String
  type      String   @default("individual")
  status    String   @default("confirmed")
  notes     String?
  createdAt DateTime @default(now())

  @@unique([slotId])
}

model SpecialistAvailability {
  id           String   @id @default(cuid())
  specialistId String
  weekday      Int
  startTime    String
  endTime      String
  duration     Int      @default(60)
  type         String   @default("individual")
  createdAt    DateTime @default(now())
}

// ── Groups & meetings ─────────────────────────────────────────────────────────

model Group {
  id             String    @id @default(cuid())
  title          String
  startDate      DateTime?
  psychologistId String?
  curatorId      String?
  status         String    @default("recruiting")
  currentWeek    Int       @default(1)
  createdAt      DateTime  @default(now())
}

model GroupParticipant {
  id                 String   @id @default(cuid())
  groupId            String
  userId             String
  status             String   @default("active")
  diaryAccessGranted Boolean  @default(false)
  joinedAt           DateTime @default(now())

  @@unique([groupId, userId])
}

model Meeting {
  id            String   @id @default(cuid())
  type          String   @default("custom")
  title         String
  description   String?
  date          String
  time          String
  duration      String   @default("90 мин")
  meetingLink   String?
  doctorId      String?
  targetTiers   String   @default("[\"intro\",\"base\",\"plus\",\"personal\"]")
  status        String   @default("scheduled")
  createdBy     String?
  groupId       String?
  participantId String?
  curatorId     String?
  recordingUrl  String?
  timezone      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GroupMeeting {
  id          String    @id @default(cuid())
  groupId     String
  week        Int       @default(1)
  title       String?
  scheduledAt DateTime?
  meetingLink String?
  notes       String?
  createdAt   DateTime  @default(now())
}

// ── Messaging ─────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime @default(now())
}

// ── Specialist tools ──────────────────────────────────────────────────────────

model SpecialistNote {
  id           String   @id @default(cuid())
  specialistId String
  userId       String
  note         String
  tags         String?
  isImportant  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Recommendation {
  id            String   @id @default(cuid())
  specialistId  String
  userId        String
  type          String   @default("session")
  summary       String
  focus         String?
  exercises     String?
  nextStep      String?
  visibleToUser Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ── User profile & notifications ──────────────────────────────────────────────

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  photoUrl    String?
  age         String?
  city        String?
  timezone    String?
  phone       String?
  telegram    String?
  about       String?
  situation   String?
  mainPain    String?
  goals       String?
  moodNow     Int?
  diaryAccess String   @default("private")
  partner     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  relatedId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

// ── Audit & consent ───────────────────────────────────────────────────────────

model ConsentLog {
  id              String   @id @default(cuid())
  userId          String
  consentType     String
  consentVersion  Int      @default(1)
  accepted        Boolean  @default(true)
  acceptedAt      DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String
  actorRole    String
  action       String
  targetUserId String?
  entityType   String?
  entityId     String?
  metadata     String?
  createdAt    DateTime @default(now())
}
